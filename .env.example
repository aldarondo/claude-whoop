# Whoop OAuth2 credentials
# Create app at: https://developer-dashboard.whoop.com/
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret

# Tokens — obtained via initial OAuth2 flow
# Run: node src/authorize.js
WHOOP_ACCESS_TOKEN=your_access_token
WHOOP_REFRESH_TOKEN=your_refresh_token
WHOOP_TOKEN_EXPIRES_AT=0
